# Upstash Redis - for storing subscribed users and their task snapshots
# Create at https://console.upstash.com/redis
UPSTASH_REDIS_URL=https://your-db.redis.upstash.io
UPSTASH_REDIS_TOKEN=your_token_here

# Resend - for sending reminder emails
# Create at https://resend.com/ (free tier: 100 emails/day)
RESEND_API_KEY=re_your_key_here

# Secret to protect the cron endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=your_secret_here

# Vercel Cron Secret (set in Vercel dashboard environment variables)
# This should match CRON_SECRET
